---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner container">
    <div class="footer-main">
      <a href="/about">Say hello</a>
    </div>
    <div class="footer-meta">
      <span>Based in Den Haag, NL</span>
      <span class="sep">·</span>
      <span>Shot on Nikon Z7II</span>
      <span class="sep">·</span>
      <span>© {year} JV Photography</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    padding: 48px 0 32px;
    margin-top: 120px;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 32px;
  }

  .footer-main {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 300;
    font-style: italic;
    letter-spacing: -0.01em;
  }

  .footer-main a {
    border-bottom: 1px solid var(--accent);
    color: var(--accent);
    padding-bottom: 2px;
  }

  .footer-main a:hover {
    color: var(--text);
    border-bottom-color: var(--text);
  }

  .footer-meta {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
    display: flex;
    gap: 12px;
  }

  .sep {
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }

    .footer-meta {
      flex-wrap: wrap;
    }
  }
</style>